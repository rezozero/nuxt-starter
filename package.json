{
  "name": "@rezozero/nuxt-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nuxi dev",
    "stories": "nuxi dev stories --port 6006 --dotenv ../.env.stories",
    "build": "nuxi build",
    "generate": "nuxi generate",
    "preview": "nuxi preview",
    "prepare": "nuxi prepare",
    "postinstall": "nuxi prepare && husky install",
    "generate:maintenance": "nuxt generate --maintenance",
    "lint": "pnpm lint:js && pnpm lint:css",
    "lint-fix": "pnpm lint:js --fix && pnpm lint:css --fix",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"**/*.{vue,css,scss}\"",
    "xilo": "node ./node_modules/@rezo-zero/xilofone-fetch/dist/index.js"
  },
  "devDependencies": {
    "@nuxt/devtools": "latest",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/icon": "^2.2.2",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/i18n": "^10.4.0",
    "@nuxtjs/robots": "^6.0.8",
    "@nuxtjs/sitemap": "^8.0.15",
    "@rezo-zero/intervention-request-provider": "^2.0.0",
    "@rezo-zero/nuxt-cache-control": "^0.1.7",
    "@rezo-zero/xilofone-fetch": "^1.0.0",
    "@roadiz/types": "^0.5.0",
    "@types/body-scroll-lock": "^3.1.2",
    "@types/json-schema": "^7.0.15",
    "@vueuse/nuxt": "^14.3.0",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "include-media": "^2.0.0",
    "nuxt": "4.3.1",
    "postcss-html": "^1.8.1",
    "postcss-pxtorem": "^6.1.0",
    "sass": "^1.100.0",
    "stylelint": "^17.12.0",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-idiomatic-order": "^10.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "typescript": "~6.0.3",
    "vite-svg-loader": "^5.1.1"
  },
  "dependencies": {
    "@floating-ui/vue": "^1.1.11",
    "@gtm-support/vue-gtm": "^3.2.0",
    "@popperjs/core": "^2.11.8",
    "@sentry/nuxt": "^10.53.1",
    "@types/lodash": "^4.17.24",
    "@vue-a11y/skip-to": "^3.0.3",
    "@vueuse/core": "^14.3.0",
    "body-scroll-lock": "^3.1.5",
    "floating-vue": "^5.2.2",
    "lodash": "^4.18.1",
    "marked": "^18.0.4",
    "ohash": "^2.0.11",
    "plyr": "^3.8.4",
    "swiper": "^12.1.4",
    "tiny-emitter": "^2.1.0",
    "v-calendar": "^3.1.2",
    "vue-multiselect": "^3.5.0"
  },
  "engines": {
    "node": "24.14.1"
  },
  "packageManager": "pnpm@9.12.0",
  "pnpm": {
    "overrides": {
      "h3@<=1.15.5": "1.15.10",
      "minimatch@>=9.0.0 <9.0.7": "9.0.9",
      "fast-xml-parser@>=5.0.0 <5.5.6": "5.5.7",
      "node-forge@<1.4.0": "1.4.0",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "yaml@>=2.0.0 <2.8.3": "2.8.3",
      "srvx@<0.11.13": "0.11.13",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": "5.0.5"
    }
  }
}
